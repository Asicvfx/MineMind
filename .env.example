# Django
DJANGO_SECRET_KEY=change-me-to-a-real-secret-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=postgres://minemind:minemind@localhost:5432/minemind
# For dev fallback you can leave empty and SQLite will be used

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# JWT
JWT_ACCESS_LIFETIME_MINUTES=60
JWT_REFRESH_LIFETIME_DAYS=14

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODEL_PRO=gpt-4o

# Google Sign-In
GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...

# Frontend
NUXT_PUBLIC_API_URL=http://localhost:8000
NUXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_test_...
NUXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
